#!/bin/sh
#
# vim-niri-nav - Use the same bindings to move focus between niri windows and
# vim splits. Requires the accompanying vim plugin.

dir="$1"
if [ -n "$2" ]; then
    if [ "$2" = "w" ]; then
        custom="or-workspace-"
    elif [ "$2" = "m" ]; then
        custom="or-monitor-"
    else
        custom=""
    fi
fi
timeout="${VIM_NIRI_NAV_TIMEOUT:-0.1}"

case "$dir" in
up|right|down|left) ;;
*)
  echo "USAGE: $0 up|right|down|left"
  exit 1
  ;;
esac

runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"

# Read PPid from /proc/<pid>/status into PPID_VAL — no process spawns.
PPID_VAL=""
_read_ppid() {
  PPID_VAL=""
  local line
  while IFS= read -r line; do
    case "$line" in
      "PPid:"*)
        PPID_VAL="${line#PPid:}"
        while :; do
          case "$PPID_VAL" in
            ' '*|'	'*) PPID_VAL="${PPID_VAL#?}" ;;
            *) break ;;
          esac
        done
        return 0
        ;;
    esac
  done < "/proc/$1/status" 2>/dev/null
  return 1
}

# Return true if $1 is a descendant of $2, walking /proc with no process spawns.
is_descendant() {
  local pid="$1" ancestor="$2" depth=0
  while [ "$depth" -lt 20 ]; do
    [ "$pid" = "$ancestor" ] && return 0
    case "$pid" in ''|0|1) return 1 ;; esac
    _read_ppid "$pid" || return 1
    pid="$PPID_VAL"
    depth="$((depth + 1))"
  done
  return 1
}

# Talk directly to nvim's msgpack-rpc socket.
# Prefers the compiled vim-niri-nav-rpc binary, falls back to Python, then nvim --headless.
_nvim_eval_via_socket() {
  _rpc_bin="$(dirname "$0")/vim-niri-nav-rpc"
  if [ -x "$_rpc_bin" ]; then
    "$_rpc_bin" "$1" "$2" "$timeout" 2>/dev/null
    return
  elif command -v vim-niri-nav-rpc >/dev/null 2>&1; then
    vim-niri-nav-rpc "$1" "$2" "$timeout" 2>/dev/null
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$1" "$2" "$timeout" 2>/dev/null <<'PYEOF'
import socket, sys, struct

def p_uint(n):
    if n < 128: return bytes([n])
    if n < 256: return b'\xcc' + bytes([n])
    return b'\xcd' + struct.pack('>H', n)

def p_str(s):
    b = s.encode()
    n = len(b)
    return (bytes([0xa0 | n]) + b) if n <= 31 else (b'\xd9' + bytes([n]) + b)

def p_arr(*items):
    return bytes([0x90 | len(items)]) + b''.join(items)

srv, expr, timeout_s = sys.argv[1], sys.argv[2], float(sys.argv[3])
msg = p_arr(p_uint(0), p_uint(1), p_str('nvim_eval'), p_arr(p_str(expr)))

s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(float(timeout_s))
try:
    s.connect(srv)
    s.sendall(msg)
    print('true' if b'true' in s.recv(256) else 'false')
except Exception:
    print('false')
PYEOF
    return
  fi

  echo "false"
}

vim_remote_expr() {
  if [ "$program" = nvim ]; then
    _nvim_eval_via_socket "$servername" "$1"
  elif [ "$program" = vim ]; then
    if command -v timeout >/dev/null 2>&1; then
      timeout "${timeout}s" vim --servername "$servername" --remote-expr "$1"
    else
      vim --servername "$servername" --remote-expr "$1"
    fi
  fi
}

# Skip niri IPC entirely when no vim instances are registered.
_has_servername=0
for _f in "$runtime_dir"/vim-niri-nav.*.servername; do
  [ -f "$_f" ] && { _has_servername=1; break; }
done

if [ "$_has_servername" = 1 ]; then
  if focused_pid="$(niri msg --json focused-window | jq -e '.pid')"; then
    for servername_file in "$runtime_dir"/vim-niri-nav.*.servername; do
      [ -f "$servername_file" ] || continue
      _base="${servername_file##*/}"
      _vim_pid="${_base#vim-niri-nav.}"
      _vim_pid="${_vim_pid%.servername}"
      if is_descendant "$_vim_pid" "$focused_pid"; then
        read -r program servername < "$servername_file"
        if [ -n "$servername" ]; then
          did_nav_in_vim=$(vim_remote_expr "VimNiriNav('$dir', 1)")
          [ "$did_nav_in_vim" = "true" ] && exit 0
        fi
        break
      fi
    done
  fi
fi

case "$dir" in
up|down)
  niri msg action focus-window-${custom}$dir
  ;;
*)
  niri msg action focus-column-$dir
  ;;
esac
